local targetNames = {
    Briefcase = true,
    Soap = true,
    Plate = true
}

local running = false

-- TELEPORT FUNCTION
local function TeleportPart()
    if running then
        return
    end

    running = true
    local character = player.Character
    if not character then
        running = false
        return
    end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        running = false
        return
    end

    -- Teleport loop
    for i = 1, 50 do
        for _, item in ipairs(itemsFolder:GetChildren()) do
            if targetNames[item.Name] then
                local handle = item:FindFirstChild("Handle")
                if handle then
                    handle.Anchored = true
                    handle.CFrame = hrp.CFrame + Vector3.new(
                        math.random(-5, 5),
                        3,
                        math.random(-5, 5)
                    )
                end
            end
        end
        task.wait(0.1)
    end

    task.wait(0.5)

    -- Unanchor items
    for _, item in ipairs(itemsFolder:GetChildren()) do
        if targetNames[item.Name] then
            local handle = item:FindFirstChild("Handle")
            if handle then
                handle.Anchored = false
            end
        end
    end
    running = false
end

