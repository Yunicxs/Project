corner.Parent = status

local function updateUI()
    if LoopEnabled then
        status.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- ON = GREEN
    else
        status.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- OFF = RED
    end
