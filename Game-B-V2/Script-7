-- Detect if the TouchInterest exists
local touchInterestPath = workspace:FindFirstChild("Map")
if touchInterestPath then
    local zones = touchInterestPath:FindFirstChild("Zones")
    if zones then
        local outside = zones:FindFirstChild("Outside")
        if outside and outside:FindFirstChild("TouchInterest") then

            -- Create mobile button (original)
            local imageButton1 = createShortcutButton(
                frame,
                "ShortcutButton4",
                UDim2.new(0.5, 5, 0, 10),
                "rbxthumb://type=Asset&id=71625940511015&w=420&h=420"
            )

            -- 🔁 TOUCH FUNCTION
            local function triggerTouch()
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    firetouchinterest(char.HumanoidRootPart, outside, 0)
                    firetouchinterest(char.HumanoidRootPart, outside, 1)
                end
            end

            -- 🔁 SAFE LOOP FUNCTION
            local function startLoop()
                if LoopThread then return end -- prevent stacking loops

                LoopThread = task.spawn(function()
                    while LoopEnabled do
                        triggerTouch()
                        task.wait(0.8)
                    end
                    LoopThread = nil -- clean up
                end)
            end

            -- 🔁 TOGGLE FUNCTION
            local function toggleLoop()
                LoopEnabled = not LoopEnabled
                updateUI()

                if LoopEnabled then
                    print("Loop ON")
                    startLoop()
                else
                    print("Loop OFF")
                end
            end

            -- =========================
            -- 📱 MOBILE BUTTON
            -- =========================
            imageButton1.MouseButton1Click:Connect(function()
                toggleLoop()
            end)

            -- =========================
            -- 💻 PC KEY (X)
            -- =========================
            UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if gameProcessed then return end

                if input.KeyCode == Enum.KeyCode.X then
                    toggleLoop()
                end
            end)

        else
            print("TouchInterest not found in Outside.")
        end
    else
        print("Zones not found in Map.")
    end
else
    print("Map not found in workspace.")
