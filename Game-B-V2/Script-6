local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- =========================
-- 🎨 GUI
-- =========================

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "HuntCountdownGui"
screenGui.Parent = playerGui
screenGui.ResetOnSpawn = false

local huntLabel = Instance.new("TextLabel")
huntLabel.Parent = screenGui
huntLabel.Size = UDim2.new(0, 120, 0, 30)
huntLabel.Position = UDim2.new(0, 130, 1, -60)
huntLabel.BackgroundTransparency = 1
huntLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
huntLabel.Font = Enum.Font.SourceSansBold
huntLabel.TextScaled = true
huntLabel.Text = ""
huntLabel.Visible = false

-- =========================
-- 🎬 FADE OUT
-- =========================

local function fadeOut()
    local tween = TweenService:Create(
        huntLabel,
        TweenInfo.new(0.5),
        {TextTransparency = 1}
    )
    tween:Play()
    tween.Completed:Wait()
    huntLabel.Visible = false
    huntLabel.TextTransparency = 0
end

-- =========================
-- 🔁 CONNECTION HANDLER
-- =========================

local valueConnection = nil

local function connectHunt(hunt)
    print("✔ HuntDuration detected")

    -- ✅ IMPORTANT FIX: HuntDuration itself is the value
    if not hunt:IsA("ValueBase") then
        print("❌ HuntDuration is not a ValueBase")
        return
    end

    print("✔ Current Value:", hunt.Value)

    -- Disconnect old connection
    if valueConnection then
        valueConnection:Disconnect()
    end

    -- Listen for value changes
    valueConnection = hunt:GetPropertyChangedSignal("Value"):Connect(function()
        local value = hunt.Value

        if value and value > 0 then
            huntLabel.Visible = true
            huntLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
            huntLabel.Text = "Hunt: " .. tostring(value)
        else
            if huntLabel.Visible then
                huntLabel.Text = "Safe"
                huntLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                fadeOut()
            end
        end
    end)
end

-- =========================
-- 🚀 INITIAL CHECK
-- =========================

local existing = ReplicatedStorage:FindFirstChild("HuntDuration")
if existing then
    connectHunt(existing)
else
    print("Waiting for HuntDuration...")
end

-- =========================
-- ⚡ INSTANT DETECT
-- =========================

ReplicatedStorage.ChildAdded:Connect(function(child)
    if child.Name == "HuntDuration" then
        connectHunt(child)
    end
end)

-- =========================
-- 🧹 CLEANUP
-- =========================

ReplicatedStorage.ChildRemoved:Connect(function(child)
    if child.Name == "HuntDuration" then
        print("❌ HuntDuration removed")

        huntLabel.Visible = false

        if valueConnection then
            valueConnection:Disconnect()
            valueConnection = nil
        end
    end
end)





