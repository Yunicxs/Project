local ItemsFolder = workspace:WaitForChild("Map"):WaitForChild("Items")

local billboards = {}
local UserInputService = game:GetService("UserInputService")

local function createESP(item)
	local handle = item:FindFirstChildWhichIsA("BasePart")
	if not handle then return end
	
	local bb = Instance.new("BillboardGui")
	bb.Adornee = handle
	bb.Size = UDim2.new(0, 200, 0, 50)
	bb.StudsOffset = Vector3.new(0, 3, 0)
	bb.AlwaysOnTop = true
	bb.Name = "ESP_" .. item.Name
	bb.Enabled = false -- Start hidden
	
	local frame = Instance.new("Frame", bb)
	frame.Size = UDim2.new(1, 0, 1, 0)
	frame.BackgroundTransparency = 1
	frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
	frame.BorderSizePixel = 0
	
	local label = Instance.new("TextLabel", bb)
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1, 1, 1)
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = Color3.new(0, 0, 0)
	label.Text = item.Name
	label.Font = Enum.Font.GothamBold
	label.TextSize = 10
	
	bb.Parent = handle
	table.insert(billboards, bb)
end

for _, item in ipairs(ItemsFolder:GetChildren()) do
	createESP(item)
end

ItemsFolder.ChildAdded:Connect(function(child)
	createESP(child)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.Equals then
		for _, bb in ipairs(billboards) do
			if bb.Parent then bb.Enabled = true end
		end

	elseif input.KeyCode == Enum.KeyCode.Minus then
		for _, bb in ipairs(billboards) do
			if bb.Parent then bb.Enabled = false end
		end
	end
end)

print("ESP loaded (hidden by default). Items: " .. #billboards)





local folder = game.Workspace.Map.Candles
local highlights = {}
local espEnabled = true

-- Services
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

-- =========================
-- 🔁 TOGGLE KEYBINDS
-- =========================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	-- Disable ESP
	if input.KeyCode == Enum.KeyCode.LeftBracket then
		espEnabled = false

		-- Remove all highlights
		for _, h in ipairs(highlights) do
			if h and h.Parent then
				h:Destroy()
			end
		end

		highlights = {}

		print("Candle ESP OFF")

	-- Enable ESP
	elseif input.KeyCode == Enum.KeyCode.RightBracket then
		espEnabled = true
		print("Candle ESP ON")
	end
end)

-- =========================
-- 🧹 CLEAR HIGHLIGHTS
-- =========================

local function clearHighlights()
	for _, h in ipairs(highlights) do
		if h and h.Parent then
			h:Destroy()
		end
	end

	highlights = {}
end

-- =========================
-- 🔥 MAIN ESP LOOP
-- =========================

task.spawn(function()

	while task.wait(1) do

		-- Remove old ESP
		clearHighlights()

		-- Skip if disabled
		if not espEnabled then
			continue
		end

		-- Scan candles
		for _, child in ipairs(folder:GetChildren()) do

			local isIgnitedVal = child:FindFirstChild("IsIgnited")

			if isIgnitedVal
				and isIgnitedVal:IsA("BoolValue")
				and isIgnitedVal.Value then

				-- Find main part
				local mainPart =
					child:FindFirstChild("Candle")
					or child:FindFirstChildWhichIsA("BasePart")
					or child

				-- Create highlight
				if mainPart and mainPart:IsA("BasePart") then

					local hl = Instance.new("Highlight")

					hl.Name = "CandleESP"
					hl.Adornee = mainPart

					hl.FillColor = Color3.fromRGB(255, 100, 0)
					hl.OutlineColor = Color3.fromRGB(255, 200, 0)

					hl.FillTransparency = 0.8
					hl.OutlineTransparency = 0

					hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

					hl.Parent = CoreGui

					table.insert(highlights, hl)
				end
			end
		end
	end
end)

print("Candle ESP Loaded")
