-- Scan unique item names
local function getItemNames()
    local names = {}
    local seen = {}
    for _, item in ipairs(itemsFolder:GetChildren()) do
        if not seen[item.Name] then
            seen[item.Name] = true
            table.insert(names, item.Name)
        end
    end
    table.sort(names)
    return names
end

