-- Bring function
local function bringSelectedItems()
    if running then return end

    local count = 0
    for _ in pairs(selectedItems) do count = count + 1 end
    if count == 0 then
        print("No items selected!")
        return
    end

    running = true
    bringButton.Text = "Bringing..."
    bringButton.BackgroundColor3 = Color3.fromRGB(170, 130, 0)

    local character = player.Character
    if not character then
        running = false
        bringButton.Text = "Bring Selected"
        bringButton.BackgroundColor3 = Color3.fromRGB(0, 170, 85)
        return
    end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        running = false
        bringButton.Text = "Bring Selected"
        bringButton.BackgroundColor3 = Color3.fromRGB(0, 170, 85)
        return
    end

    -- Phase 1: Anchor and teleport
    for i = 1, 50 do
        for _, item in ipairs(itemsFolder:GetChildren()) do
            if selectedItems[item.Name] then
                local handle = item:FindFirstChild("Handle")
                if handle then
                    handle.Anchored = true
                    handle.CFrame = hrp.CFrame + Vector3.new(
                        math.random(-5, 5), 3, math.random(-5, 5)
                    )
                end
            end
        end
        task.wait(0.1)
    end

    -- Phase 2: Unanchor and keep teleporting for 5 seconds
    local startTime = tick()
    while tick() - startTime < 5 do
        for _, item in ipairs(itemsFolder:GetChildren()) do
            if selectedItems[item.Name] then
                local handle = item:FindFirstChild("Handle")
                if handle then
                    handle.Anchored = false
                    handle.CFrame = hrp.CFrame + Vector3.new(
                        math.random(-5, 5), 3, math.random(-5, 5)
                    )
                end
            end
        end
        task.wait(0.1)
    end

    print("Done! Selected items teleported.")
    bringButton.Text = "Bring Selected"
    bringButton.BackgroundColor3 = Color3.fromRGB(0, 170, 85)
    running = false
end

bringButton.MouseButton1Click:Connect(function()
    bringSelectedItems()
end)

-- Auto Drop Toggle
local function updateAutoDropButton()
    if autoDropRunning then
        autoDropButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
    else
        autoDropButton.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
    end
end

autoDropButton.MouseButton1Click:Connect(function()
    autoDropRunning = not autoDropRunning
    updateAutoDropButton()
end)

-- PC KEYBIND (RightShift)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then
        return
    end

    if input.KeyCode == Enum.KeyCode.RightShift then
        autoDropRunning = not autoDropRunning
        updateAutoDropButton()
    end
end)

-- PC keybind (comma) brings all items
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Comma then
        -- Select all and bring
        local names = getItemNames()
        for _, name in ipairs(names) do
            selectedItems[name] = true
        end
        -- Update checkboxes
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("Frame") then
                local cb = child:FindFirstChild("CheckBox")
                if cb then cb.Text = "✓" end
            end
        end
        bringSelectedItems()
    end
end)

