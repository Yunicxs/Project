-- Function to simulate touch event on any object with TouchInterest
local function simulateTouch(part)
    if not part then return end
    local touchInterest = part:FindFirstChild("TouchInterest")
    
    -- Check if part has a TouchInterest
    if touchInterest and part:IsA("BasePart") then
        local char = player.Character or player.CharacterAdded:Wait()
        local humanoidRootPart = char:FindFirstChild("HumanoidRootPart")
        
        -- Ensure valid part is found for simulation
        if humanoidRootPart then
            -- Fire touch events
            firetouchinterest(humanoidRootPart, part, 0) -- Touch begin
            task.wait(0.1) -- Short delay before touch ends
            firetouchinterest(humanoidRootPart, part, 1) -- Touch end
            print("Touched: " .. part:GetFullName())
        end
    end
end

-- Function to continuously scan for objects with TouchInterest
local function findAndTouchObjects()
    local objectsToTouch = {}

    -- Collect all objects in workspace with TouchInterest
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("BasePart") and obj:FindFirstChild("TouchInterest") then
            table.insert(objectsToTouch, obj)
        end
    end

    -- If there are objects to touch, show the GUI and let the player interact
    if #objectsToTouch > 0 then
        label.Text = "Found " .. tostring(#objectsToTouch) .. " objects to touch!"
        
        for _, obj in ipairs(objectsToTouch) do
            yesButton.MouseButton1Click:Connect(function()
                simulateTouch(obj)
                
                -- Wait for 1 second between each firetouchinterest call to prevent freezing
                task.wait(1)  -- Add a 1-second delay before simulating the next touch
                
                -- Remove the touched object from the list and re-check
                table.remove(objectsToTouch, table.find(objectsToTouch, obj))
                
                if #objectsToTouch == 0 then
                    label.Text = "No objects left to touch!"
                    task.wait(2) -- Wait for a second before closing
                    gui:Destroy()
                end
            end)
        end
    else
        label.Text = "No objects left with TouchInterest!"
        task.wait(2)
        gui:Destroy()
    end
end

-- Continuously check for objects with TouchInterest
while true do
    findAndTouchObjects()
    task.wait(1) -- Check every second for remaining objects
end
