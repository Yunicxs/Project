-- Recursive scan function
local function findEggs(parent)
	local eggs = {}
	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("Instance") then
			if child.Name == "Egg" then
				table.insert(eggs, child)
			end
			-- Recursively search children
			local foundInChild = findEggs(child)
			for _, egg in ipairs(foundInChild) do
				table.insert(eggs, egg)
			end
		end
	end
	return eggs
end

