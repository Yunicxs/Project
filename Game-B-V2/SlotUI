-- ============================================================
-- TOGGLE ANIMATE
local baseX = 16
local baseY = -46  -- bottom anchor offset

local function toggleUI()
	isOpen = not isOpen

	local targetWidth = isOpen and expandedWidth or collapsedSize
	local targetHeight = isOpen and expandedHeight or collapsedSize
	local targetRotation = isOpen and 180 or 0

	-- When expanding, shift position up by the height difference
	local heightDiff = expandedHeight - collapsedSize
	local targetY = isOpen and (baseY - heightDiff) or baseY

	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

	if isOpen then
		contentFrame.Visible = true
	end

	TweenService:Create(mainFrame, tweenInfo, {
		Size = UDim2.new(0, targetWidth, 0, targetHeight),
		Position = UDim2.new(0, baseX, 1, targetY)
	}):Play()
	TweenService:Create(arrowLabel, tweenInfo, {Rotation = targetRotation}):Play()

	if not isOpen then
		task.delay(0.26, function()
			contentFrame.Visible = false
		end)
	end
end
header.MouseButton1Click:Connect(toggleUI)

