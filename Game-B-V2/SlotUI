	slotLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	slotLayout.Parent = slotContainer

	return row
end

-- ============================================================
-- REFRESH ALL PLAYERS
-- ============================================================
local function refresh()
	for _, child in ipairs(innerFrame:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		local row = createPlayerRow(plr)
		row.LayoutOrder = plr.UserId
		row.Parent = innerFrame

		local slotContainer = row:FindFirstChild("SlotContainer")
		if slotContainer then
			for i = 1, slotCount do
				local slotValue = plr:FindFirstChild("Slot" .. i)
				if slotValue and slotValue:IsA("ValueBase") then
					local val = slotValue.Value
					if val ~= nil and val ~= "" and val ~= 0 then
						local slotLabel = Instance.new("TextLabel")
						slotLabel.Name = "Slot" .. i
						slotLabel.Size = UDim2.new(0, 28, 1, 0)
						slotLabel.LayoutOrder = i
						slotLabel.BackgroundTransparency = 1
						slotLabel.Text = tostring(val)
						slotLabel.TextColor3 = Color3.fromRGB(180, 220, 130)
						slotLabel.TextSize = 11
						slotLabel.Font = Enum.Font.Gotham
						slotLabel.TextXAlignment = Enum.TextXAlignment.Center
						slotLabel.TextTruncate = Enum.TextTruncate.AtEnd
						slotLabel.Parent = slotContainer
					end
				end
			end
		end
	end
end

-- ============================================================
-- LIVE UPDATE LOOP
-- ============================================================
local function startLiveUpdate()
	task.spawn(function()
		while screenGui.Parent do
			for _, plr in ipairs(Players:GetPlayers()) do
				local row = innerFrame:FindFirstChild(plr.Name)
				if row then
					local slotContainer = row:FindFirstChild("SlotContainer")
					if slotContainer then
						local activeSlots = {}
						for i = 1, slotCount do
							local slotValue = plr:FindFirstChild("Slot" .. i)
							if slotValue and slotValue:IsA("ValueBase") then
								local val = slotValue.Value
								local isEmpty = (val == nil or val == "" or val == 0)
								activeSlots[i] = { value = val, isEmpty = isEmpty }
							end
						end

						local needsRebuild = false
						local existingLabels = {}
						for _, child in ipairs(slotContainer:GetChildren()) do
							if child:IsA("TextLabel") then
								existingLabels[child.Name] = child
							end
						end

						for name, label in pairs(existingLabels) do
							local slotNum = tonumber(name:match("%d+"))
							if slotNum then
								local slotData = activeSlots[slotNum]
								if not slotData or slotData.isEmpty then
									needsRebuild = true
									break
								elseif tostring(slotData.value) ~= label.Text then
									label.Text = tostring(slotData.value)
								end
							end
						end

						if not needsRebuild then
							for i = 1, slotCount do
								local slotData = activeSlots[i]
								if slotData and not slotData.isEmpty then
									if not existingLabels["Slot" .. i] then
										needsRebuild = true
										break
									end
								end
							end
						end

						if needsRebuild then
							for _, child in ipairs(slotContainer:GetChildren()) do
								if child:IsA("TextLabel") then
									child:Destroy()
								end
							end
							for i = 1, slotCount do
								local slotData = activeSlots[i]
								if slotData and not slotData.isEmpty then
									local slotLabel = Instance.new("TextLabel")
									slotLabel.Name = "Slot" .. i
									slotLabel.Size = UDim2.new(0, 28, 1, 0)
									slotLabel.LayoutOrder = i
									slotLabel.BackgroundTransparency = 1
									slotLabel.Text = tostring(slotData.value)
									slotLabel.TextColor3 = Color3.fromRGB(180, 220, 130)
									slotLabel.TextSize = 11
									slotLabel.Font = Enum.Font.Gotham
									slotLabel.TextXAlignment = Enum.TextXAlignment.Center
									slotLabel.TextTruncate = Enum.TextTruncate.AtEnd
									slotLabel.Parent = slotContainer
								end
							end
						end
					end
				end
			end
			task.wait(0.5)
		end
	end)
end

-- ============================================================
-- EVENTS
