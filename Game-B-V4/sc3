-- Variables to track blinking
local sessionBlinkCount = 0
local totalBlinkCount = 0
local lastBlinkDuration = 0
local isBlinking = false
local blinkStartTime = 0
local ghost = nil
local head = nil
local headHighlight = nil
local wasHunting = false
local huntingSessionStarted = false
local huntingSessionEnded = false
local huntingStableCount = 0

-- Statistics tracking
local sessionBlinkDurations = {}

-- Function to initialize ghost tracking
local function initializeGhostTracking()
    ghost = Workspace:FindFirstChild("Ghost")
    if not ghost then
        -- Try to find ghost in ReplicatedStorage and wait for it to be loaded
        local ghostModelFolder = game.ReplicatedStorage:FindFirstChild("GhostModel")
        if ghostModelFolder then
            ghost = ghostModelFolder:FindFirstChild("Ghost")
        end
    end
    
    if ghost then
        head = ghost:FindFirstChild("Head")
        local highlightStorage = CoreGui:FindFirstChild("Ghost_Highlight_Storage")
        if highlightStorage then
            headHighlight = highlightStorage:FindFirstChild("GhostHighlight_Head")
        end
        
        if head and headHighlight then
            return true
        end
    end
    
    return false
end

-- Function to check if ghost is hunting
local function isGhostHunting()
    -- First check if ghost exists
    if not ghost or not ghost.Parent then
        return false
    end
    
    -- Then check the hunting property
    if ghost:FindFirstChild("Hunting") then
        return ghost.Hunting.Value
    end
    
    return false
end

-- Function to calculate statistics
local function calculateBlinkStats()
    if #sessionBlinkDurations == 0 then
        return 0, 0, 0
    end
    
    local minDuration = math.huge
    local maxDuration = 0
    local totalDuration = 0
    
    for _, duration in ipairs(sessionBlinkDurations) do
        if duration < minDuration then
            minDuration = duration
        end
        if duration > maxDuration then
            maxDuration = duration
        end
        totalDuration = totalDuration + duration
    end
    
    return minDuration, maxDuration, totalDuration
end

-- Function to reset session tracking (but not total blinks)
local function resetSessionTracking()
    -- Print statistics before resetting
    if #sessionBlinkDurations > 0 then
        local minDuration, maxDuration, totalDuration = calculateBlinkStats()
        print("=== Ghost Hunting Session Ended ===")
        print("Session Blinks:", #sessionBlinkDurations)
        print("Fastest Blink:", minDuration .. "ms")
        print("Longest Blink:", maxDuration .. "ms")
        if #sessionBlinkDurations > 0 then
            print("Average Blink:", math.floor((totalDuration / #sessionBlinkDurations) + 0.5) .. "ms")
        end
        print("===================================")
    end
    
    -- Reset session tracking variables (but not total blinks)
    lastBlinkDuration = 0
    isBlinking = false
    blinkStartTime = 0
    huntingSessionEnded = true
    
    -- Keep sessionBlinkCount displayed in UI
    -- Reset UI
    durationLabel.Text = "0ms"
    statusBox.BackgroundTransparency = 0.5 -- Reset to visible state
end

-- Try to initialize immediately
local initialized = initializeGhostTracking()

-- If not initialized, set up a connection to try again when ghost appears
if not initialized then
    local connection
    connection = Workspace.ChildAdded:Connect(function(child)
        if child.Name == "Ghost" then
            wait(1) -- Wait a bit for everything to load
            if initializeGhostTracking() then
                connection:Disconnect()
            end
        end
    end)
end

-- Main detection loop
RunService.Heartbeat:Connect(function()
    -- Check if ghost exists
    local currentGhost = Workspace:FindFirstChild("Ghost")
    
    -- If ghost disappeared, reset session tracking
    if ghost and not currentGhost then
        if huntingSessionStarted and not huntingSessionEnded then
            resetSessionTracking()
        end
        ghost = nil
        head = nil
        headHighlight = nil
        initialized = false
        huntingSessionStarted = false
        huntingSessionEnded = false
        huntingStableCount = 0
        return
    end
    
    -- If not initialized but ghost exists, try to initialize
    if not initialized and currentGhost then
        initialized = initializeGhostTracking()
        if not initialized then return end
    end
    
    -- If ghost doesn't exist, return
    if not ghost or not head or not headHighlight then return end
    
    -- Check hunting status
    local hunting = isGhostHunting()
    
    -- Stabilize hunting detection to prevent flickering
    if hunting == wasHunting then
        huntingStableCount = math.min(huntingStableCount + 1, 10) -- Cap at 10 frames
    else
        huntingStableCount = 0
    end
    
    -- Only act on hunting state if it's been stable for a few frames
    if huntingStableCount >= 3 then
        -- Check if hunting just started (and we're not already in a session)
        if hunting and not huntingSessionStarted and not huntingSessionEnded then
            huntingSessionStarted = true
            huntingSessionEnded = false
            -- Reset session blinks only when hunting starts (not total blinks)
            sessionBlinkDurations = {}
            sessionBlinkCount = 0
            countLabel.Text = tostring(sessionBlinkCount)
        end
        
        -- Check if hunting state changed from true to false (and we were in a session)
        if not hunting and huntingSessionStarted and not huntingSessionEnded then
            -- Ghost just finished hunting, reset session tracking
            resetSessionTracking()
        end
    end
    
    -- Update previous hunting state
    wasHunting = hunting
    
    -- Check if head exists and is valid
    if not head or not head.Parent then return end
    
    -- Method 1: Check head transparency
    local headInvisible = (head.Transparency >= 0.95)  -- Almost invisible
    
    -- Use head transparency as the main indicator
    if headInvisible and not isBlinking then
        -- Blink started
        isBlinking = true
        blinkStartTime = tick()
        statusBox.BackgroundTransparency = 1 -- Make transparent when blinking (opposite state)
    elseif not headInvisible and isBlinking then
        -- Blink ended
        isBlinking = false
        local duration = (tick() - blinkStartTime) * 1000  -- Convert to ms
        lastBlinkDuration = math.floor(duration + 0.5)  -- Round to nearest ms
        sessionBlinkCount = sessionBlinkCount + 1
        totalBlinkCount = totalBlinkCount + 1
        
        -- Store duration for statistics only during active hunting
        if huntingSessionStarted and not huntingSessionEnded then
            table.insert(sessionBlinkDurations, lastBlinkDuration)
        end
        
        statusBox.BackgroundTransparency = 0.5 -- Make visible when not blinking (current state)
    end
    
    -- Update UI
    countLabel.Text = tostring(sessionBlinkCount)
    durationLabel.Text = tostring(lastBlinkDuration) .. "ms"
end)







