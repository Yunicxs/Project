-- Running Script synced to UI
-- Keybind: LeftShift to toggle, B to increase, C to decrease
-- Uses Speed TextLabel to show only speed value, Run ImageLabel for color
-- Default speed: 6.5, Current speed: 12 (adjustable)
-- end info script

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = game:GetService("Players").LocalPlayer
local CoreGui = game:GetService("CoreGui")

local toggle = false
local keybindToggle = Enum.KeyCode.LeftShift
local keybindIncrease = Enum.KeyCode.B
local keybindDecrease = Enum.KeyCode.C
local speedLoop = nil
local defaultSpeed = 6.5 -- Speed when OFF
local currentSpeed = 13.5  -- Speed when ON (changeable)

-- Wait for ToggleUI
local toggleUI = CoreGui:WaitForChild("ToggleUI")
local tframe = toggleUI:WaitForChild("TFrame")
local toogleUI = tframe:WaitForChild("ToogleUI")
local runLabel = toogleUI:WaitForChild("Run")
local speedLabel = tframe:WaitForChild("Speed")

-- Function to start speed loop
local function startSpeedLoop(speed)
    -- Stop any existing loop
    if speedLoop then
        speedLoop:Disconnect()
        speedLoop = nil
    end
    
    -- Start new loop
    speedLoop = RunService.RenderStepped:Connect(function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = speed
        end
    end)
end

-- Function to update GUI
local function updateGUI()
    if toggle then
        speedLabel.Text = tostring(currentSpeed)
        speedLabel.TextColor3 = Color3.fromRGB(0, 255, 0) -- Green
        runLabel.ImageColor3 = Color3.fromRGB(144, 238, 144) -- light green
    else
        speedLabel.Text = tostring(defaultSpeed)
        speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- White
        runLabel.ImageColor3 = Color3.fromRGB(255, 255, 255) -- white
    end
end

-- Toggle function
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- Toggle speed on/off
    if input.KeyCode == keybindToggle then
        toggle = not toggle
        if toggle then
            startSpeedLoop(currentSpeed) -- ON: Uses adjustable speed
        else
            startSpeedLoop(defaultSpeed) -- OFF: Stays at 6.5
        end
        updateGUI()
    end

    -- Increase speed (only when ON)
    if input.KeyCode == keybindIncrease and toggle then
        currentSpeed = currentSpeed + 2
        startSpeedLoop(currentSpeed) -- Apply new speed immediately
        updateGUI()
    end

    -- Decrease speed (only when ON)
    if input.KeyCode == keybindDecrease and toggle then
        if currentSpeed > 1 then -- Prevents negative speed
            currentSpeed = currentSpeed - 2
            startSpeedLoop(currentSpeed) -- Apply new speed immediately
            updateGUI()
        end
    end
end)
