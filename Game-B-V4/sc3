-- info script
-- Fullbright Toggle integrated into ToggleUI
-- Keybind: T
-- ImageColor3: white = off, light green = on
-- end info script

-- Color constants
local COLOR_ON = Color3.fromRGB(144, 238, 144)  -- light green
local COLOR_OFF = Color3.fromRGB(255, 255, 255)  -- white

-- Toggle state
local FullBrightEnabled = false

-- Store original settings
local OriginalSettings = {
	Brightness = Lighting.Brightness,
	ClockTime = Lighting.ClockTime,
	FogEnd = Lighting.FogEnd,
	GlobalShadows = Lighting.GlobalShadows,
	OutdoorAmbient = Lighting.OutdoorAmbient
}

-- Store Atmosphere instances
local SavedAtmospheres = {}

-- Apply Fullbright
local function enableFullBright()
	SavedAtmospheres = {}
	for _, v in pairs(Lighting:GetDescendants()) do
		if v:IsA("Atmosphere") then
			table.insert(SavedAtmospheres, v:Clone())
			v:Destroy()
		end
	end

	Lighting.Brightness = 1
	Lighting.ClockTime = 14
	Lighting.FogEnd = 100000
	Lighting.GlobalShadows = false
	Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)

	Fullbright.ImageColor3 = COLOR_ON
end

-- Restore original settings
local function disableFullBright()
	Lighting.Brightness = OriginalSettings.Brightness
	Lighting.ClockTime = OriginalSettings.ClockTime
	Lighting.FogEnd = OriginalSettings.FogEnd
	Lighting.GlobalShadows = OriginalSettings.GlobalShadows
	Lighting.OutdoorAmbient = OriginalSettings.OutdoorAmbient

	for _, v in pairs(SavedAtmospheres) do
		v.Parent = Lighting
	end

	Fullbright.ImageColor3 = COLOR_OFF
end

-- Toggle function
local function toggleFullBright()
	FullBrightEnabled = not FullBrightEnabled

	if FullBrightEnabled then
		enableFullBright()
	else
		disableFullBright()
	end
end

-- Keybind (T)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if input.KeyCode == Enum.KeyCode.T then
		toggleFullBright()
	end
end)


