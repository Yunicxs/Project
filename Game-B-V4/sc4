local function updateSelectedLabel(name)
	if name and name ~= "" and name ~= "No Ghost Found" then
		selectedLabel.Text = "Selected: " .. name
	else
		selectedLabel.Text = "Selected: None"
	end
end

-- hook into selectGhost so the label updates on every selection
local _origSelect = _G.SGC.selectGhost
_G.SGC.selectGhost = function(name)
	local ok, nm = _origSelect(name)
	updateSelectedLabel(ok and nm or "")
	return ok, nm
end

-- watch journal Selection boxes so manual clicks in the Journal sync the label
local function watchTemplate(template)
	local sel = template:FindFirstChild("Selection")
	if not sel or not sel:IsA("ImageLabel") then return end
	local more = template:FindFirstChild("More")
	local nameTL = more and more:FindFirstChild("TextLabel")
	if not nameTL then return end

	sel:GetPropertyChangedSignal("ImageTransparency"):Connect(function()
		if sel.ImageTransparency == 0 then
			-- enforce single selection: deselect all OTHER templates
			local frame = getGhostFrame()
			if frame then
				for _, c in ipairs(frame:GetChildren()) do
					if c ~= template and c:IsA("ImageButton") and c.Name == "GhostTemplate" then
						local s = c:FindFirstChild("Selection")
						if s and s:IsA("ImageLabel") then
							s.ImageTransparency = 1
						end
					end
				end
			end
			updateSelectedLabel(nameTL.Text)
		else
			-- if this one just got deselected, check if any other is selected
			local frame = getGhostFrame()
			local stillSelected = nil
			if frame then
				for _, c in ipairs(frame:GetChildren()) do
					if c:IsA("ImageButton") and c.Name == "GhostTemplate" then
						local s = c:FindFirstChild("Selection")
						local m = c:FindFirstChild("More")
						local t = m and m:FindFirstChild("TextLabel")
						if s and s:IsA("ImageLabel") and s.ImageTransparency == 0 and t then
							stillSelected = t.Text
						end
					end
				end
			end
			updateSelectedLabel(stillSelected or "")
		end
	end)
end

local function watchAllTemplates()
	local frame = getGhostFrame()
	if not frame then return end
	for _, c in ipairs(frame:GetChildren()) do
		if c:IsA("ImageButton") and c.Name == "GhostTemplate" then
			watchTemplate(c)
		end
	end
end

watchAllTemplates()

-- in case templates are (re)created later (e.g. journal rebuild), watch the frame's children
local gf = getGhostFrame()
if gf then
	gf.ChildAdded:Connect(function(child)
		if child:IsA("ImageButton") and child.Name == "GhostTemplate" then
			watchTemplate(child)
		end
	end)
end

-- AutoIgnitedCandles - Manual ignite via keybind E

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local CandlesFolder = workspace.Map.Candles
local LightCandle = ReplicatedStorage.Remotes.LightCandle

-- All candle/light targets.
local IgniteTargets = {}

for _, obj in ipairs(CandlesFolder:GetChildren()) do
    if obj.Name == "Light" and obj:IsA("Model") then
        table.insert(IgniteTargets, obj)
    elseif obj.Name == "Candle" and obj:IsA("BasePart") then
        table.insert(IgniteTargets, obj)
    end
end


local function GetCharacterRoot()
    local char = LocalPlayer.Character
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function GetTargetPosition(target)
    if target:IsA("Model") then
        if target.PrimaryPart then
            return target.PrimaryPart.Position
        end
        return target:GetPivot().Position
    end
    return target.Position
end

local function IsAlreadyLit(target)
    local flag = target:FindFirstChild("IsIgnited")
    return flag and flag:IsA("BoolValue") and flag.Value == true
end


local function GetPromptFor(target)
    if target:IsA("Model") then
        local holder = target:FindFirstChild("lightholder")
        if holder then
            return holder:FindFirstChild("IgniteCandlePrompt")
        end
    else
        return target:FindFirstChild("IgniteCandlePrompt")
    end
    return nil
end

local function SyncPrompts()
    for _, target in ipairs(IgniteTargets) do
        if target and target.Parent then
            local prompt = GetPromptFor(target)
            if prompt and prompt:IsA("ProximityPrompt") then
                if IsAlreadyLit(target) then
                    prompt.Enabled = false
                else
                    prompt.Enabled = true
                    prompt.HoldDuration = 0
                    prompt.MaxActivationDistance = 10
                end
            end
        end
    end
end

RunService:BindToRenderStep(
    "AutoIgnitedCandles_PromptSync",
    Enum.RenderPriority.Last.Value,
    SyncPrompts
)


local MANUAL_RANGE = 15

local function IgniteNearestManual()
    local root = GetCharacterRoot()
    if not root then return end
    local myPos = root.Position

    local best, bestDist = nil, MANUAL_RANGE
    for _, target in ipairs(IgniteTargets) do
        if target and target.Parent and not IsAlreadyLit(target) then
            local dist = (GetTargetPosition(target) - myPos).Magnitude
            if dist <= bestDist then
                bestDist = dist
                best = target
            end
        end
    end

    if best then
        local ok, err = pcall(function()
            LightCandle:FireServer(best)
        end)
        if not ok then
            warn("[AutoIgnitedCandles] manual ignite error:", err)
        end
    end
end

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.E then
        IgniteNearestManual()
    end
end)

local AutoIgniteEnabled = false   -- starts OFF; press LeftAlt to toggle
local AUTO_RANGE = 10
local AUTO_STEP_DELAY = 0.1      -- seconds between auto passes

local function TryAutoIgnite()
    if not AutoIgniteEnabled then return end

    local root = GetCharacterRoot()
    if not root then return end
    local myPos = root.Position

    for _, target in ipairs(IgniteTargets) do
        if target and target.Parent and not IsAlreadyLit(target) then
            local dist = (GetTargetPosition(target) - myPos).Magnitude
            if dist <= AUTO_RANGE then
                local ok, err = pcall(function()
                    LightCandle:FireServer(target)
                end)
                if not ok then
                    warn("[AutoIgnitedCandles] auto ignite error:", err)
                end
            end
        end
    end
end

local lastAuto = 0
RunService.Heartbeat:Connect(function(dt)
    lastAuto = lastAuto + dt
    if lastAuto >= AUTO_STEP_DELAY then
        lastAuto = 0
        local ok, err = pcall(TryAutoIgnite)
        if not ok then
            warn("[AutoIgnitedCandles] auto loop error:", err)
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.LeftAlt then
        AutoIgniteEnabled = not AutoIgniteEnabled
    end
end)

