-- Read all ghost names from the template buttons
local function getGhostNames()
	local frame = getGhostFrame()
	local names = {}
	if not frame then return names end
	for _, child in ipairs(frame:GetChildren()) do
		if child:IsA("ImageButton") and child.Name == "GhostTemplate" then
			local more = child:FindFirstChild("More")
			if more then
				local tl = more:FindFirstChild("TextLabel")
				if tl and tl:IsA("TextLabel") then
					local txt = tl.Text
					if txt and txt ~= "" then
						table.insert(names, txt)
					end
				end
			end
		end
	end
	return names
end

-- Returns the GhostTemplate whose name == target (case-insensitive)
local function findGhostTemplate(name)
	local frame = getGhostFrame()
	if not frame then return nil end
	local lowered = string.lower(name)
	for _, child in ipairs(frame:GetChildren()) do
		if child:IsA("ImageButton") and child.Name == "GhostTemplate" then
			local more = child:FindFirstChild("More")
			if more then
				local tl = more:FindFirstChild("TextLabel")
				if tl and tl:IsA("TextLabel") then
					if string.lower(tl.Text) == lowered then
						return child
					end
				end
			end
		end
	end
	return nil
end

-- Sync the Selection ImageTransparency for all templates based on chosen name
local function syncSelection(chosenName)
	local frame = getGhostFrame()
	if not frame then return end
	local lowered = chosenName and string.lower(chosenName) or ""
	for _, child in ipairs(frame:GetChildren()) do
		if child:IsA("ImageButton") and child.Name == "GhostTemplate" then
			local sel = child:FindFirstChild("Selection")
			if sel and sel:IsA("ImageLabel") then
				local more = child:FindFirstChild("More")
				local isMatch = false
				if more then
					local tl = more:FindFirstChild("TextLabel")
					if tl and tl:IsA("TextLabel") then
						isMatch = (string.lower(tl.Text) == lowered)
					end
				end
				sel.ImageTransparency = isMatch and 0 or 1
			end
		end
	end
end

-- Fire the remote; if not found send "No Ghost Found"
local function selectGhost(name)
	local template = findGhostTemplate(name)
	if template then
		SelectGhostEvent:FireServer(name)
		syncSelection(name)
		return true, name
	else
		SelectGhostEvent:FireServer("No Ghost Found")
		syncSelection("") -- clear all
		return false, name
	end
end

