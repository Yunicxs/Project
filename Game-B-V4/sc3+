--[[
    GhostWalkspeedDetection (v3)
    - Shows ONLY the live WalkSpeed text above the Ghost (no card/bar/gradient).
    - Color tween: green flash on increase, red flash on decrease, white when stable.
    - INFINITE range: MaxDistance = 0 (never invisible), LightInfluence = 0.
    - Event-driven (PropertyChangedSignal) -> accurate, no lag.
    - Spawn via ChildAdded -> no polling. Single GUI, auto-cleanup, no duplicates.
--]]

local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local GHOST_NAME = "Ghost"

local COL_BASE   = Color3.fromRGB(255, 255, 255) -- stable
local COL_UP     = Color3.fromRGB(255, 80, 80)  -- increased
local COL_DOWN   = Color3.fromRGB(80, 255, 120)   -- decreased

local active = {
    ghost = nil,
    gui = nil,
    text = nil,
    colorTween = nil,
    speedConn = nil,
    rtConn = nil,
    lastSpeed = nil,
}

local function safeDestroy(inst)
    if inst and inst:IsA("Instance") and inst.Parent then
        inst:Destroy()
    end
end

local function cleanup()
    if active.speedConn then active.speedConn:Disconnect() active.speedConn = nil end
    if active.rtConn then active.rtConn:Disconnect() active.rtConn = nil end
    if active.colorTween then active.colorTween:Cancel() active.colorTween = nil end
    safeDestroy(active.gui)
    active.gui = nil
    active.text = nil
    active.ghost = nil
    active.lastSpeed = nil
end

-- minimal: just a speed text label, no backgrounds
local function createBillboard(ghost)
    local adornee = ghost:FindFirstChild("HumanoidRootPart")
        or ghost:FindFirstChild("Head")
        or ghost.PrimaryPart

    local text = Instance.new("TextLabel")
    text.Name = "SpeedText"
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.BorderSizePixel = 0
    text.Font = Enum.Font.GothamBold
    text.TextSize = 24
    text.Text = "-"
    text.TextColor3 = COL_BASE
    text.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    text.TextStrokeTransparency = 0.35
    text.TextScaled = false

    local gui = Instance.new("BillboardGui")
    gui.Name = "GhostSpeedUI"
    gui.Size = UDim2.new(0, 220, 0, 60)
    gui.StudsOffset = Vector3.new(0, 3.2, 0)
    gui.AlwaysOnTop = true
    gui.MaxDistance = 0          -- INFINITE range: never invisible when far
    gui.LightInfluence = 0
    gui.Adornee = adornee
    text.Parent = gui
    gui.Parent = adornee or ghost
    return gui, text
end

local function setColor(target)
    if active.colorTween then active.colorTween:Cancel() end
    active.colorTween = TweenService:Create(
        active.text,
        TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { TextColor3 = target }
    )
    active.colorTween:Play()
    -- settle back to base white after the flash
    task.delay(0.45, function()
        if active.text and active.text.Parent then
            if active.colorTween then active.colorTween:Cancel() end
            active.colorTween = TweenService:Create(
                active.text,
                TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { TextColor3 = COL_BASE }
            )
            active.colorTween:Play()
        end
    end)
end

local function refresh(ghost)
    local hum = ghost:FindFirstChildOfClass("Humanoid")
    if not hum or not active.text then return end

    local ws = hum.WalkSpeed
    active.text.Text = string.format("%.2f", ws)

    if active.lastSpeed ~= nil then
        if ws > active.lastSpeed + 1e-4 then
            setColor(COL_UP)
        elseif ws < active.lastSpeed - 1e-4 then
            setColor(COL_DOWN)
        end
    end
    active.lastSpeed = ws
end

local function attach(ghost)
    if active.ghost == ghost then return end -- already tracking
    cleanup()                                -- no duplicates
    active.ghost = ghost

    local gui, text = createBillboard(ghost)
    active.gui = gui
    active.text = text

    local hum = ghost:FindFirstChildOfClass("Humanoid")
        or ghost:WaitForChild("Humanoid", 5)
    if hum then
        active.speedConn = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            refresh(ghost)
        end)
        refresh(ghost) -- init
    end

    active.rtConn = ghost.AncestryChanged:Connect(function()
        if not ghost:IsDescendantOf(workspace) then
            cleanup()
        end
    end)
end

-- spawn detection
workspace.ChildAdded:Connect(function(child)
    if child.Name == GHOST_NAME and child:IsA("Model") then
        task.defer(attach, child)
    end
end)

local existing = workspace:FindFirstChild(GHOST_NAME)
if existing then task.defer(attach, existing) end

-- safety cleanup if ghost destroyed
RunService.Heartbeat:Connect(function()
    if active.ghost and not active.ghost:IsDescendantOf(workspace) then
        cleanup()
    end
end)



