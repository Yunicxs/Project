-- Optimized THH&PGB Challenge Detection Script
-- Uses event-based monitoring and cached instances for better performance
-- Constants
local COLOR_GOLD = Color3.fromRGB(255, 215, 0)
local COLOR_YELLOW = Color3.fromRGB(255, 128, 128)
local COLOR_GRAY = Color3.fromRGB(255, 0, 0)

-- Required subjects table (for fast lookup)
local REQUIRED_SUBJECTS = {
    ["Cursed Object"] = true,
    ["Boo-Boo Doll"] = true,
    ["Burning Crucifix"] = true,
    ["Ghost"] = true
}

-- Cache for performance optimization
local cachedInstances = {
    photoSubjects = {},
    selections = {},
    thhComplete = THHComplete
}

-- Cache PhotoSubject instances on startup (using simple GetDescendants approach)
local function cachePhotoSubjects()
    cachedInstances.photoSubjects = {}
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    -- Get all PhotoSubject textlabels using GetDescendants
    for _, instance in ipairs(playerGui:GetDescendants()) do
        if instance.Name == "PhotoSubject" and instance:IsA("TextLabel") then
            table.insert(cachedInstances.photoSubjects, instance)
        end
    end
end

-- Cache Selection instances on startup (using simple GetDescendants approach)
local function cacheSelections()
    cachedInstances.selections = {}
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    -- Get all Selection imagelabels using GetDescendants
    for _, instance in ipairs(playerGui:GetDescendants()) do
        if instance.Name == "Selection" and instance:IsA("ImageLabel") then
            table.insert(cachedInstances.selections, instance)
        end
    end
end

-- Check PhotoSubjects completion (using cached instances)
local function checkPhotoSubjects()
    local foundSubjects = {}
    local foundCount = 0
    
    for _, photoSubject in ipairs(cachedInstances.photoSubjects) do
        if photoSubject:IsA("TextLabel") then
            local text = photoSubject.Text or ""
            if REQUIRED_SUBJECTS[text] then
                foundSubjects[text] = true
                foundCount = foundCount + 1
            end
        end
    end
    
    local allFound = foundCount == 4
    return allFound, foundCount, 4
end

-- Check Selections completion (using cached instances)
local function checkSelections()
    local selectedFound = false
    
    for _, selection in ipairs(cachedInstances.selections) do
        if selection:IsA("ImageLabel") and selection.ImageTransparency == 0 then
            selectedFound = true
            break
        end
    end
    return selectedFound
end

-- Smooth fading "Bip (fade out) . . ." radar-like animation for COLOR_YELLOW and COLOR_GRAY
local blinkThread = nil
local shouldBlink = false

local function startBlinkingAnimation()
    -- Stop any existing animation
    shouldBlink = false
    if blinkThread then
        pcall(function() task.cancel(blinkThread) end)
        blinkThread = nil
    end
    
    -- Start new animation
    shouldBlink = true
    blinkThread = task.spawn(function()
        while shouldBlink and cachedInstances.thhComplete do
            -- Make fully visible (bip appears)
            cachedInstances.thhComplete.ImageTransparency = 0
            
            -- Hold at full visibility for 0.5 seconds
            task.wait(0.000005)
            
            -- Smooth fade out (bip disappears)
            for i = 1, 20 do
                if not shouldBlink or not cachedInstances.thhComplete then return end
                cachedInstances.thhComplete.ImageTransparency = i/20
                task.wait(0.0005) -- Smooth fade out over 0.5 seconds
            end
            
            -- Gap before next bip (0.5 seconds)
            task.wait(1)
        end
        
        -- Ensure it's visible when animation stops
        if cachedInstances.thhComplete then
            cachedInstances.thhComplete.ImageTransparency = 0
        end
    end)
end

local function stopBlinkingAnimation()
    shouldBlink = false
    if blinkThread then
        pcall(function() task.cancel(blinkThread) end)
        blinkThread = nil
    end
    
    -- Ensure visibility when stopped
    if cachedInstances.thhComplete then
        cachedInstances.thhComplete.ImageTransparency = 0
    end
end

-- Update THHComplete ImageLabel color
local function updateTHHColor(step1Complete, step2Complete)
    if not cachedInstances.thhComplete then
        return 
    end
    
    local newColor
    if step1Complete and step2Complete then
        newColor = COLOR_GOLD
    elseif step1Complete or step2Complete then
        newColor = COLOR_YELLOW
    else
        newColor = COLOR_GRAY
    end
    
    cachedInstances.thhComplete.ImageColor3 = newColor
    
    -- Start or stop blinking animation based on color
    if newColor == COLOR_YELLOW or newColor == COLOR_GRAY then
        startBlinkingAnimation()
    else
        stopBlinkingAnimation()
    end
end

-- Main check function (optimized to use cached instances)
local function checkChallenges()
    local step1Complete, step1Found, step1Total = checkPhotoSubjects()
    local step2Complete = checkSelections()
    
    updateTHHColor(step1Complete, step2Complete)
end

-- Setup event-based monitoring instead of constant polling
local function setupMonitoring()
    -- Monitor for new PhotoSubjects and Selections being added
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        local function onDescendantAdded(instance)
            if instance.Name == "PhotoSubject" and instance:IsA("TextLabel") then
                -- Add to cache if not already there
                local found = false
                for _, existing in ipairs(cachedInstances.photoSubjects) do
                    if existing == instance then
                        found = true
                        break
                    end
                end
                if not found then
                    table.insert(cachedInstances.photoSubjects, instance)
                end
            elseif instance.Name == "Selection" and instance:IsA("ImageLabel") then
                -- Add to cache if not already there
                local found = false
                for _, existing in ipairs(cachedInstances.selections) do
                    if existing == instance then
                        found = true
                        break
                    end
                end
                if not found then
                    table.insert(cachedInstances.selections, instance)
                end
            end
        end
        
        playerGui.DescendantAdded:Connect(onDescendantAdded)
        
        -- Also cleanup removed instances
        local function onDescendantRemoved(instance)
            for i, photoSubject in ipairs(cachedInstances.photoSubjects) do
                if photoSubject == instance then
                    table.remove(cachedInstances.photoSubjects, i)
                    break
                end
            end
            for i, selection in ipairs(cachedInstances.selections) do
                if selection == instance then
                    table.remove(cachedInstances.selections, i)
                    break
                end
            end
        end
        
        playerGui.DescendantAdded:Connect(onDescendantAdded)
        playerGui.DescendantRemoving:Connect(onDescendantRemoved)
    end
    
    -- Initial cache and check
    cachePhotoSubjects()
    cacheSelections()
    checkChallenges()
    
    -- Periodic check with longer interval since we're mostly event-driven
    task.spawn(function()
        while true do
            task.wait(0.5)  -- Check every 0.5 seconds
            checkChallenges()
        end
    end)
end

