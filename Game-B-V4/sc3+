    end
end

-- Refresh Adornee each frame so ESP follows the player's current Workspace model
-- (keeps ESP alive when dead, since the model stays in Workspace)
local function syncESP()
    for player, entry in pairs(espEntries) do
        if not player or not player.Parent then
            -- Player removed from Players service entirely -> clean up
            removePlayerESP(player)
        else
            local root = getRootPart(player)
            if root and entry.billboard then
                entry.billboard.Adornee = root
            end
        end
    end
end

