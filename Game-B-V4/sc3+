_G.SGC.box = box
_G.SGC.dropdown = dropdown
_G.SGC.dlayout = dlayout

-- Step 3: autocomplete dropdown logic
local MIN_CHARS = 1
local selectedIndex = 0
local currentSuggestions = {}

local function clearDropdown()
	for _, c in ipairs(dropdown:GetChildren()) do
		if c:IsA("TextButton") then c:Destroy() end
	end
end

local function highlightItems()
	for i, item in ipairs(currentSuggestions) do
		local btn = item.button
		if i == selectedIndex then
			btn.BackgroundColor3 = Color3.fromRGB(60, 80, 110)
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		else
			btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
			btn.TextColor3 = Color3.fromRGB(210, 210, 225)
		end
	end
end

local function makeItem(name, index)
	local btn = Instance.new("TextButton")
	btn.Name = "Item"
	btn.Size = UDim2.new(1, -8, 0, 26)
	btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	btn.BorderSizePixel = 0
	btn.AutoButtonColor = false
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 14
	btn.TextColor3 = Color3.fromRGB(210, 210, 225)
	btn.TextXAlignment = Enum.TextXAlignment.Left
	btn.Text = "  " .. name
	btn.LayoutOrder = index
	btn.Parent = dropdown

	local bc = Instance.new("UICorner")
	bc.CornerRadius = UDim.new(0, 6)
	bc.Parent = btn

	btn.MouseButton1Click:Connect(function()
		box.Text = name
		_G.SGC.selectGhost(name)
		closeUI()
	end)
	return btn
end

local function refreshDropdown()
	clearDropdown()
	currentSuggestions = {}
	local txt = string.lower(string.sub(box.Text, 1, -1))
	local names = getGhostNames()

	if #box.Text >= MIN_CHARS then
		for _, name in ipairs(names) do
			if string.find(string.lower(name), txt, 1, true) then
				local idx = #currentSuggestions + 1
				local btn = makeItem(name, idx)
				table.insert(currentSuggestions, {name = name, button = btn})
			end
		end
	end

	if #currentSuggestions > 0 then
		dropdown.Visible = true
		dropdown.Size = UDim2.new(1, 0, 0, math.min(#currentSuggestions, 8) * 28 + 6)
		selectedIndex = 1
		highlightItems()
	else
		dropdown.Visible = false
		selectedIndex = 0
	end
end

-- strip any ";" that lands in the box (e.g. from the trigger key)
box:GetPropertyChangedSignal("Text"):Connect(function()
	local t = box.Text
	if string.find(t, ";", 1, true) then
		box.Text = string.gsub(t, ";", "")
	end
	refreshDropdown()
end)

-- Step 4: open/close + keybind handling
local open = false

local function openUI()
	open = true
	container.Visible = true
	box.Text = ""
	dropdown.Visible = false
	currentSuggestions = {}
	selectedIndex = 0
	-- defer focus to next frame so the ";" keystroke isn't captured into the box
	task.defer(function()
		if open then box:CaptureFocus() end
	end)
end

local function closeUI()
	open = false
	container.Visible = false
	dropdown.Visible = false
	box:ReleaseFocus()
	clearDropdown()
	currentSuggestions = {}
	selectedIndex = 0
end

_G.SGC.inputConn = UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end

	-- toggle with ;
	if input.KeyCode == Enum.KeyCode.Semicolon then
		if open then
			closeUI()
		else
			openUI()
		end
		return
	end

	if not open then return end

	if input.KeyCode == Enum.KeyCode.Escape then
		closeUI()
		return
	end

	if input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.KeypadEnter then
		if selectedIndex > 0 and currentSuggestions[selectedIndex] then
			local name = currentSuggestions[selectedIndex].name
			box.Text = name
			_G.SGC.selectGhost(name)
		else
			-- submit raw text (min 1 char)
			local raw = string.gsub(box.Text, ";", "")
			if #raw >= MIN_CHARS then
				_G.SGC.selectGhost(raw)
			end
		end
		closeUI()
		return
	end

	if input.KeyCode == Enum.KeyCode.Up then
		if #currentSuggestions > 0 then
			selectedIndex = selectedIndex - 1
			if selectedIndex < 1 then selectedIndex = #currentSuggestions end
			highlightItems()
		end
		return
	end

	if input.KeyCode == Enum.KeyCode.Down then
		if #currentSuggestions > 0 then
			selectedIndex = selectedIndex + 1
			if selectedIndex > #currentSuggestions then selectedIndex = 1 end
			highlightItems()
		end
		return
	end
end)

-- Step 5: selected-ghost label (bottom-left of screen)
local selectedLabel = Instance.new("TextLabel")
selectedLabel.Name = "SelectedGhost"
selectedLabel.Size = UDim2.new(0, 260, 0, 22)
selectedLabel.Position = UDim2.new(0, 14, 0.87, 0) -- bottom-left corner
selectedLabel.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
selectedLabel.BackgroundTransparency = 1
selectedLabel.BorderSizePixel = 0
selectedLabel.Text = "Selected: -"
selectedLabel.TextColor3 = Color3.fromRGB(120, 220, 160)
selectedLabel.Font = Enum.Font.Gotham
selectedLabel.TextSize = 14
selectedLabel.TextXAlignment = Enum.TextXAlignment.Left
selectedLabel.Parent = gui

local slCorner = Instance.new("UICorner")
slCorner.CornerRadius = UDim.new(0, 8)
slCorner.Parent = selectedLabel

local slStroke = Instance.new("UIStroke")
slStroke.Color = Color3.fromRGB(90, 90, 120)
slStroke.Thickness = 1
slStroke.Transparency = 0.4
slStroke.Parent = selectedLabel

local function updateSelectedLabel(name)
	if name and name ~= "" and name ~= "No Ghost Found" then
		selectedLabel.Text = "Selected: " .. name
	else
		selectedLabel.Text = "Selected: None"
	end
end

-- hook into selectGhost so the label updates on every selection
local _origSelect = _G.SGC.selectGhost
_G.SGC.selectGhost = function(name)
	local ok, nm = _origSelect(name)
	updateSelectedLabel(ok and nm or "")
	return ok, nm
end

-- watch journal Selection boxes so manual clicks in the Journal sync the label
local function watchTemplate(template)
	local sel = template:FindFirstChild("Selection")
	if not sel or not sel:IsA("ImageLabel") then return end
	local more = template:FindFirstChild("More")
	local nameTL = more and more:FindFirstChild("TextLabel")
	if not nameTL then return end

	sel:GetPropertyChangedSignal("ImageTransparency"):Connect(function()
		if sel.ImageTransparency == 0 then
			-- enforce single selection: deselect all OTHER templates
			local frame = getGhostFrame()
			if frame then
				for _, c in ipairs(frame:GetChildren()) do
					if c ~= template and c:IsA("ImageButton") and c.Name == "GhostTemplate" then
						local s = c:FindFirstChild("Selection")
						if s and s:IsA("ImageLabel") then
							s.ImageTransparency = 1
						end
					end
				end
			end
			updateSelectedLabel(nameTL.Text)
		else
			-- if this one just got deselected, check if any other is selected
			local frame = getGhostFrame()
			local stillSelected = nil
			if frame then
				for _, c in ipairs(frame:GetChildren()) do
					if c:IsA("ImageButton") and c.Name == "GhostTemplate" then
						local s = c:FindFirstChild("Selection")
						local m = c:FindFirstChild("More")
						local t = m and m:FindFirstChild("TextLabel")
						if s and s:IsA("ImageLabel") and s.ImageTransparency == 0 and t then
							stillSelected = t.Text
						end
					end
				end
			end
			updateSelectedLabel(stillSelected or "")
		end
	end)
end

local function watchAllTemplates()
	local frame = getGhostFrame()
	if not frame then return end
	for _, c in ipairs(frame:GetChildren()) do
		if c:IsA("ImageButton") and c.Name == "GhostTemplate" then
			watchTemplate(c)
		end
	end
end

watchAllTemplates()

-- in case templates are (re)created later (e.g. journal rebuild), watch the frame's children
local gf = getGhostFrame()
if gf then
	gf.ChildAdded:Connect(function(child)
		if child:IsA("ImageButton") and child.Name == "GhostTemplate" then
			watchTemplate(child)
		end
	end)
end
