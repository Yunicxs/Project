        task.wait(0.2)
        if handle and handle.Parent then
            pcall(function()
                handle:SetNetworkOwner(player)
            end)
        end
    end)

    task.wait(0.5)
    if handle and handle.Parent then
        handle.Anchored = false
    end

    -- Cooldown timer
    task.spawn(function()
