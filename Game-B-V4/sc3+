-- Function to check if Slow Players TextLabel is present/visible
local function isSlowPlayersActive()
    -- Look for the "Slow Players" TextLabel in the Challenges frame
    local challengesFrame = game.Workspace.Map.Van.Van.TimerModel.Monitor.SurfaceGui:FindFirstChild("Challenges")
    if not challengesFrame then
        return false
    end
    
    local slowPlayersLabel = challengesFrame:FindFirstChild("Slow Players")
    if not slowPlayersLabel then
        return false
    end
    
    return slowPlayersLabel.Visible
end

-- Modified updateGUI function to respect Slow Players priority
local function updateGUI()
    if isSlowPlayersActive() then
        -- Slow Players detection takes priority
        return -- Don't update normal colors if Slow Players is active
    end
    
    -- Normal speed update logic
    if toggle then
        speedLabel.Text = tostring(currentSpeed)
        speedLabel.TextColor3 = Color3.fromRGB(0, 255, 0) -- Green
        if runLabel.ImageColor3 ~= SlowPlayersColor then
            runLabel.ImageColor3 = Color3.fromRGB(144, 238, 144) -- light green
        end
    else
        speedLabel.Text = tostring(defaultSpeed)
        speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- White
        if runLabel.ImageColor3 ~= SlowPlayersColor then
            runLabel.ImageColor3 = Color3.fromRGB(255, 255, 255) -- white
        end
    end
end

-- Function to update Run label for slow players challenge
local function updateSlowPlayersUI()
    if not runLabel then return end
    
    local isActive = isSlowPlayersActive()
    
    if isActive then
        runLabel.ImageColor3 = SlowPlayersColor
    else
        -- If Slow Players is deactivated, restore normal colors
        if updateGUI then
            updateGUI()
        end
    end
end

