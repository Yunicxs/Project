-- 🎬 Click Animation
local function animateClick()
    button:TweenSize(
        UDim2.new(0, 26, 0, 26),
        Enum.EasingDirection.Out,
        Enum.EasingStyle.Quad,
        0.08,
        true,
        function()
            button:TweenSize(
                UDim2.new(0, 30, 0, 30),
                Enum.EasingDirection.Out,
                Enum.EasingStyle.Quad,
                0.08,
                true
            )
        end
    )
end

button.MouseButton1Click:Connect(function()
    animateClick()
    runRemote()
end)

