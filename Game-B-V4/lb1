    {"All", 0}, {"Lv.10", 10}, {"Lv.25", 25}, {"Lv.50", 50}, {"Lv.75", 75}, {"Lv.100", 100}
}

local levelButtons = {}
for i, opt in ipairs(levelOptions) do
    local btn = createButton(opt[1], opt[2], function(val, btn)
        CurrentSettings.MinLevel = val
        for _, b in pairs(levelButtons) do
            b.BackgroundColor3 = (b == btn) and Color3.fromRGB(80, 150, 80) or Color3.fromRGB(50, 50, 50)
        end
    end)
    btn.Position = UDim2.new(0, (i-1)%3 * 80, 0, math.floor((i-1)/3) * 30)
    btn.Parent = LevelContainer
    table.insert(levelButtons, btn)
end
levelButtons[1].BackgroundColor3 = Color3.fromRGB(80, 150, 80)

