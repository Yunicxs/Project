-- Save Functionality
SaveBtn.MouseButton1Click:Connect(function()
    CurrentSettings.Description = DescInput.Text
    
    local settings = {
        MaxPlayers = 99,
        IsLocked = CurrentSettings.IsLocked,
        MinLevel = CurrentSettings.MinLevel,
        VoiceChatOnly = false,
        Description = CurrentSettings.Description,
        DisabledGamepasses = {}
    }
    
    local success, err = ClientGateway:Invoke("hostUpdateSettings", settings)
    if success then
        print("Lobby Settings Saved!")
    else
        warn("Failed: " .. tostring(err))
    end
    ScreenGui.Enabled = false -- Close UI after saving
end)

