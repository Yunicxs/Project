local UserInputService = game:GetService("UserInputService")

local holdingShift = false
local debounce = false

-- Safe loader wrapper: catches errors so one failure doesn't block the rest
local function safeLoad(name, url)
    print("Loading " .. name .. "...")
    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)
    if not success then
        warn("[IYAI] Failed to load " .. name .. ": " .. tostring(err))
    end
end

-- LOADERS
local function loadInfiniteYield()
    safeLoad("Infinite Yield", "https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source")
end

local function loadRemoteSpy()
    safeLoad("RemoteSpy", "https://github.com/notpoiu/cobalt/releases/latest/download/Cobalt.luau")
end

local function loadDex()
    safeLoad("Dex", "https://raw.githubusercontent.com/Yunicxs/Project/refs/heads/main/RandomV1/Dex")
end

local function IYAI()
    safeLoad("IYAI", "https://raw.githubusercontent.com/Yunicxs/Project/refs/heads/main/RandomV1/IYAI-Loaders")
end

local function FC()
    safeLoad("FC", "https://raw.githubusercontent.com/Yunicxs/Project/refs/heads/main/RandomV1/FreeCam")
end

local function CB()
    safeLoad("CB", "https://raw.githubusercontent.com/Yunicxs/Project/refs/heads/main/RandomV1/Cobalt.lua")
end

local function EM()
    safeLoad("EM", "https://rawscripts.net/raw/Universal-Script-emote-script-7yd7-63469")
end

-- =========================
-- INPUT HANDLER
-- =========================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- Detect RightControl (used as modifier)
    if input.KeyCode == Enum.KeyCode.RightControl then
        holdingShift = true
    end

    -- Prevent spam
    if debounce then return end

    if holdingShift then
        local key = input.KeyCode

        if key == Enum.KeyCode.K then
            debounce = true
            loadInfiniteYield()

        elseif key == Enum.KeyCode.P then
            debounce = true
            loadRemoteSpy()

        elseif key == Enum.KeyCode.N then
            debounce = true
            CB()

        elseif key == Enum.KeyCode.M then
            debounce = true
            IYAI()

        elseif key == Enum.KeyCode.Quote then
            debounce = true
            FC()

        elseif key == Enum.KeyCode.RightBracket then
            debounce = true
            EM()

        elseif key == Enum.KeyCode.L then
            debounce = true
            loadDex()
        end

        -- Cooldown (always resets debounce even if load errored)
        task.wait(0.5)
        debounce = false
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.RightControl then
        holdingShift = false
    end
end)
