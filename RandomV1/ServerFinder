loadstring(game:HttpGet("https://raw.githubusercontent.com/Yunicxs/Project/refs/heads/main/RandomV1/sb.txt"))()

local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local screenGui = playerGui:WaitForChild("RSB23")
local header = screenGui.MainWindow.Header
local refBtn = header:WaitForChild("RefBtn")

-- Set GUI to hidden immediately on first run
screenGui.Enabled = false

-- 1. Toggle Logic (F4)
local toggleKey = Enum.KeyCode.F4
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == toggleKey then
        screenGui.Enabled = not screenGui.Enabled
    end
end)

-- 2. Save Server on Leave
Players.PlayerRemoving:Connect(function(plr)
    if plr == player then
        local currentServer = {
            PlaceId = game.PlaceId,
            JobId = game.JobId
        }
        pcall(function()
            writefile("lastServer.json", HttpService:JSONEncode(currentServer))
        end)
    end
end)

-- 3. Create Server Buttons with cloned styling
local function createServerButtons()
    -- Destroy existing buttons if they exist
    local existingLS = header:FindFirstChild("LastServerBtn")
    if existingLS then existingLS:Destroy() end
    
    local existingRJ = header:FindFirstChild("RejoinBtn")
    if existingRJ then existingRJ:Destroy() end

    local function applyStyle(btn, text)
        btn.Text = text
        btn.Size = UDim2.new(0, 70, 0, 28) -- Made smaller than RefBtn (96)
        btn.BackgroundColor3 = refBtn.BackgroundColor3
        btn.BackgroundTransparency = refBtn.BackgroundTransparency
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 8
        btn.Font = refBtn.Font
        btn.ZIndex = refBtn.ZIndex

        local refCorner = refBtn:FindFirstChildOfClass("UICorner")
        if refCorner then
            local corner = Instance.new("UICorner")
            corner.CornerRadius = refCorner.CornerRadius
            corner.Parent = btn
        end

        local refStroke = refBtn:FindFirstChildOfClass("UIStroke")
        if refStroke then
            local stroke = Instance.new("UIStroke")
            stroke.Color = refStroke.Color
            stroke.Thickness = refStroke.Thickness
            stroke.Transparency = refStroke.Transparency
            stroke.Parent = btn
        end
    end

    -- Last Server Button
    local lsBtn = Instance.new("TextButton")
    lsBtn.Name = "LastServerBtn"
    applyStyle(lsBtn, "Last Server")
    lsBtn.Position = UDim2.new(1, -180 - 70 - 5, 0.5, -14)
    lsBtn.Parent = header

    -- Rejoin Button
    local rjBtn = Instance.new("TextButton")
    rjBtn.Name = "RejoinBtn"
    applyStyle(rjBtn, "Rejoin")
    rjBtn.Position = UDim2.new(1, -180 - 70 - 5 - 70 - 5, 0.5, -14)
    rjBtn.Parent = header

    -- LS Logic
    lsBtn.MouseButton1Click:Connect(function()
        local success, data = pcall(function() return HttpService:JSONDecode(readfile("lastServer.json")) end)
        if success and data then
            TeleportService:TeleportToPlaceInstance(data.PlaceId, data.JobId, player)
        else
            warn("Last server not found")
            lsBtn.Text = "Not Found!"
            task.wait(1)
            lsBtn.Text = "Last Server"
        end
    end)

    -- Rejoin Logic
    rjBtn.MouseButton1Click:Connect(function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
end

createServerButtons()
