-- Function to set RoomName ScreenGui enabled state
local function disableRoomName()
	local playerGui = LocalPlayer:WaitForChild("PlayerGui")
	local roomNameGui = playerGui:FindFirstChild("RoomName")
	
	if roomNameGui and roomNameGui:IsA("ScreenGui") then
		roomNameGui.Enabled = false
	end
end

