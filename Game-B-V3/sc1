            humanoidRootPart.CFrame = CFrame.new(switchPosition)
            wait(0.1)
            
            -- Fire ProximityPrompt - find it reliably
            local prompt = lightSwitch:FindFirstChildWhichIsA("ProximityPrompt")
            if prompt and fireproximityprompt then
                fireproximityprompt(prompt)
            end
            
