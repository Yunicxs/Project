local UserInputService = game:GetService("UserInputService")

local Loaded = false

local function FC()
	print("Loading FC...")
	loadstring(game:HttpGet("https://raw.githubusercontent.com/Yunicxs/Project/refs/heads/main/RandomV1/FreeCam"))()
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed or Loaded then
		return
	end

	if input.KeyCode == Enum.KeyCode.Quote then
		Loaded = true -- set BEFORE running

		task.spawn(function()
			FC()
		end)
	end
end)
