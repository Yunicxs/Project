-- AnimationUI

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local IdleTime = 3
local LastHover = tick()

local FadeEnabled = false
local MouseInside = false

local FadeTweenInfo = TweenInfo.new(
	1,
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)

local FadeObjects = {
	GhostStatus,
	PlayerStatus
}

local function IsMouseInside(Frame)
	local MousePos = UserInputService:GetMouseLocation()

	local Pos = Frame.AbsolutePosition
	local Size = Frame.AbsoluteSize

	return MousePos.X >= Pos.X
		and MousePos.X <= Pos.X + Size.X
		and MousePos.Y >= Pos.Y
		and MousePos.Y <= Pos.Y + Size.Y
end

local function TweenObject(Object, Transparency)
	if Object:IsA("Frame") then
		TweenService:Create(Object, FadeTweenInfo, {
			BackgroundTransparency = Transparency
		}):Play()

	elseif Object:IsA("ImageLabel") or Object:IsA("ImageButton") then
		TweenService:Create(Object, FadeTweenInfo, {
			ImageTransparency = Transparency
		}):Play()
	end
end

local function SetUITransparency(Transparency)
	for _,UI in ipairs(FadeObjects) do
		for _,Object in ipairs(UI:GetDescendants()) do
			TweenObject(Object, Transparency)
		end
	end
end

local function RestoreUI()
	if not FadeEnabled then
		return
	end

	FadeEnabled = false
	SetUITransparency(0)
end

local function FadeUI()
	if FadeEnabled then
		return
	end

	FadeEnabled = true
	SetUITransparency(0.7)
end

task.spawn(function()
	while StatusUI.Parent do
		MouseInside = false

		for _,UI in ipairs(FadeObjects) do
			if IsMouseInside(UI) then
				MouseInside = true
				LastHover = tick()
				break
			end
		end

		if MouseInside then
			RestoreUI()
		else
			if tick() - LastHover >= IdleTime then
				FadeUI()
			end
		end

		task.wait(0.1)
	end
end)

-- End of AnimationUI

