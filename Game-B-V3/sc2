local function updateHuntState()
	if not HuntDuration or not HuntText then return end

	local ghost = ghostExists()
	local duration = HuntDuration.Value

	if ghost and duration > 0 then
		if not huntActive then
			huntActive = true
			HuntText.Text = "Ghost : Hunting"
			animateCountdown(duration)
		end
	elseif ghost then
		if huntActive then
			huntActive = false
			stopCountdown()
			setBarToEmpty()
		end
		HuntText.Text = "Ghost : Manifest"
		startManifestPulse()
		if GCountdown then GCountdown.Text = "" end
	else
		if huntActive then
			huntActive = false
			stopCountdown()
		end
		HuntText.Text = "Ghost : None"
		stopManifestPulse()
		setBarToEmpty()
		if GCountdown then GCountdown.Text = "" end
	end
end

