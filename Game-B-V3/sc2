-------------------------------------------------
-- Helper: safely get a child, return nil if missing
-------------------------------------------------
local function safeGet(parent, name)
	if not parent then return nil end
	return parent:FindFirstChild(name)
end

-------------------------------------------------
-- Ghost utilities
-------------------------------------------------
local function ghostExists()
	return workspace:FindFirstChild("Ghost") ~= nil
end

local function findClosestZone(position)
	if not ZonesFolder then return nil end
	local closestZone = nil
	local closestDist = math.huge

	for _, zone in ipairs(ZonesFolder:GetChildren()) do
		if zone:IsA("BasePart") and safeGet(zone, "IsZone") and zone.IsZone.Value == true then
			local exclude = safeGet(zone, "Exclude")
			if not (exclude and exclude.Value == true) then
				local dist = (zone.Position - position).Magnitude
				if dist < closestDist then
					closestDist = dist
					closestZone = zone
				end
			end
		end
	end

	return closestZone
end

local function findColdestZone()
	if not ZonesFolder then return nil end
	local coldestZone = nil
	local lowestTemp = math.huge

	for _, zone in ipairs(ZonesFolder:GetChildren()) do
		if zone:IsA("BasePart") and safeGet(zone, "IsZone") and zone.IsZone.Value == true then
			local exclude = safeGet(zone, "Exclude")
			if not (exclude and exclude.Value == true) then
				local tempObj = safeGet(zone, "_____Temperature")
				if tempObj and tempObj.Value < lowestTemp then
					lowestTemp = tempObj.Value
					coldestZone = zone
				end
			end
		end
	end

	return coldestZone
end

local function getZoneTempString(zone)
	if not zone then return "0.10" end
	local tempObj = safeGet(zone, "_____Temperature")
	if tempObj then
		local baseTemp = safeGet(tempObj, "_____LocalBaseTemp")
		if baseTemp then
			return string.format("%.2f", baseTemp.Value)
		end
		return string.format("%.2f", tempObj.Value)
	end
	return "0.10"
end

