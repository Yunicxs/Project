local function setBarToEmpty()
	if not BarCountdown then return end
	BarCountdown.AnchorPoint = Vector2.new(0, 0.5)
	BarCountdown.Position = UDim2.new(0, 0, 0.5, 0)
	BarCountdown.Size = UDim2.new(0, 0, 1, 0)
	BarCountdown.BackgroundColor3 = HUNT_COLOR
	BarCountdown.BackgroundTransparency = 0
end

local function setBarToFull()
	if not BarCountdown then return end
	BarCountdown.AnchorPoint = Vector2.new(0, 0.5)
	BarCountdown.Position = UDim2.new(0, 0, 0.5, 0)
	BarCountdown.Size = UDim2.new(1, 0, 1, 0)
end

local function startManifestPulse()
	if not BarCountdown then return end
	stopManifestPulse()
	stopCountdown()

	BarCountdown.BackgroundColor3 = MANIFEST_COLOR
	setBarToFull()

	manifestPulseConnection = RunService.Heartbeat:Connect(function()
		if BarCountdown and BarCountdown.Parent then
			BarCountdown.BackgroundTransparency = Random.new():NextNumber(0, 0.5)
		end
	end)
end

local function animateCountdown(duration)
	if not BarCountdown or not GCountdown then return end
	stopCountdown()
	stopManifestPulse()

	if duration <= 0 then
		setBarToEmpty()
		GCountdown.Text = ""
		huntActive = false
		return
	end

	BarCountdown.BackgroundColor3 = HUNT_COLOR
	BarCountdown.BackgroundTransparency = 0
	BarCountdown.AnchorPoint = Vector2.new(0, 0.5)
	BarCountdown.Position = UDim2.new(0, 0, 0.5, 0)
	BarCountdown.Size = UDim2.new(1, 0, 1, 0)

	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.In)
	local goal = { Size = UDim2.new(0, 0, 1, 0) }

	currentTween = TweenService:Create(BarCountdown, tweenInfo, goal)
	currentTween:Play()

	local elapsed = 0
	countdownConnection = RunService.Heartbeat:Connect(function(dt)
		elapsed = elapsed + dt
		local remaining = math.ceil(duration - elapsed)
		if remaining < 0 then remaining = 0 end
		if GCountdown and GCountdown.Parent then
			GCountdown.Text = tostring(remaining) .. "s"
		end
		if remaining <= 0 then
			if countdownConnection then
				countdownConnection:Disconnect()
				countdownConnection = nil
			end
		end
	end)

	currentTween.Completed:Connect(function()
		if GCountdown and GCountdown.Parent then
			GCountdown.Text = ""
		end
		currentTween = nil
		huntActive = false
	end)
end

