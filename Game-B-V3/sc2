-- =========================
-- OBJECTIVES
-- =========================

local function getObjectives()

	local objectivesFrame = workspace
		:WaitForChild("Map")
		:WaitForChild("Van")
		:WaitForChild("Screens")
		:WaitForChild("Whiteboard")
		:WaitForChild("SurfaceGui")
		:WaitForChild("Frame")
		:FindFirstChild("Objectives")

	if not objectivesFrame then
		return {}
	end

	local objectives = {}

	for _, child in ipairs(objectivesFrame:GetChildren()) do
		if child:IsA("TextLabel") and child:FindFirstChild("HasCompleted") then

			table.insert(objectives,{
				name = child.Text or "",
				hasCompleted = child.HasCompleted.Value or false
			})
		end
	end

	return objectives
end

local function updateObjectivesDisplay()

	local objectives = getObjectives()

	-- Clear old labels
	for _, child in ipairs(ObjectivesContainer:GetChildren()) do
		if child:IsA("TextLabel") then
			child:Destroy()
		end
	end

	-- Create labels
	for i, objective in ipairs(objectives) do

		local objectiveLabel = Instance.new("TextLabel")
		objectiveLabel.Name = "ObjectiveLabel"
		objectiveLabel.Parent = ObjectivesContainer
		objectiveLabel.BackgroundTransparency = 1
		objectiveLabel.Text = objective.name
		objectiveLabel.TextColor3 = objective.hasCompleted
			and COMPLETE_COLOR
			or INCOMPLETE_COLOR

		objectiveLabel.TextSize = 18
		objectiveLabel.FontFace = originalFont
		objectiveLabel.TextXAlignment = Enum.TextXAlignment.Right
		objectiveLabel.TextYAlignment = Enum.TextYAlignment.Top
		objectiveLabel.LayoutOrder = i
		objectiveLabel.AutomaticSize = Enum.AutomaticSize.Y
		objectiveLabel.Size = UDim2.new(1,0,0,20)

		if objective.hasCompleted then
			objectiveLabel.Text = objective.name
			objectiveLabel.TextColor3 = COMPLETE_COLOR
		end
	end

	UIListLayout:ApplyLayout()
end

-- =========================
-- MONITORING
-- =========================

local function setupMonitoring()

	local objectivesFrame = workspace
		:WaitForChild("Map")
		:WaitForChild("Van")
		:WaitForChild("Screens")
		:WaitForChild("Whiteboard")
		:WaitForChild("SurfaceGui")
		:WaitForChild("Frame")
		:FindFirstChild("Objectives")

	if not objectivesFrame then
		return
	end

	objectivesFrame.DescendantAdded:Connect(function(child)
		if child:IsA("TextLabel") and child:FindFirstChild("HasCompleted") then
			updateObjectivesDisplay()
		end
	end)

	objectivesFrame.DescendantRemoving:Connect(function(child)
		if child:IsA("TextLabel") and child:FindFirstChild("HasCompleted") then
			updateObjectivesDisplay()
		end
	end)

	for _, child in ipairs(objectivesFrame:GetChildren()) do
		if child:IsA("TextLabel") and child:FindFirstChild("HasCompleted") then

			local hasCompleted = child:FindFirstChild("HasCompleted")

			if hasCompleted then
				hasCompleted:GetPropertyChangedSignal("Value"):Connect(function()
					updateObjectivesDisplay()
				end)
			end
		end
	end
end

-- Initial load FIRST
updateObjectivesDisplay()

-- =========================
-- FADE-IN ANIMATION
-- ONLY RUNS ONCE
-- =========================

local FadeTween = TweenInfo.new(
	0.6,
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)

task.spawn(function()

	task.wait(0.001)

	local TextLabels = {}

	-- Collect all labels first
	for _, Object in ipairs(MainFrame:GetDescendants()) do
		if Object:IsA("TextLabel") then
			Object.TextTransparency = 1
			table.insert(TextLabels,Object)
		end
	end

	-- Animate after ALL labels exist
	for _, Object in ipairs(TextLabels) do

		local Tween = TweenService:Create(
			Object,
			FadeTween,
			{
				TextTransparency = 0
			}
		)

		Tween:Play()

		task.wait(0.6)
	end
end)

-- Start monitoring AFTER animation setup
setupMonitoring()

-- Backup refresh loop
task.spawn(function()
	while task.wait(5) do
		updateObjectivesDisplay()
	end
end)




-- AutoLeave Script
-- Keybind: ] to run
-- Teleports to LightSwitch, fires ProximityPrompt at index 4, then returns to original position

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

local lightSwitch = game.Workspace.Map.Van.Van.LeaveButton.LightSwitch
local isRunning = false

local function autoLeave()
    if isRunning then return end
    isRunning = true
    
    local originalCFrame = humanoidRootPart.CFrame
    
    spawn(function()
        pcall(function()
            -- Teleport to LightSwitch
            local switchPosition = lightSwitch.Position + Vector3.new(0, 3, 0)
            humanoidRootPart.CFrame = CFrame.new(switchPosition)
            wait(0.5)
            
            -- Fire ProximityPrompt at index 4
            local prompt = lightSwitch:GetChildren()[4]
            if prompt and prompt:IsA("ProximityPrompt") then
                if fireproximityprompt then
                    fireproximityprompt(prompt)
                end
            end
            
            wait(0.5)
            
            -- Return to original position
            humanoidRootPart.CFrame = originalCFrame
            wait(0.5)
        end)
        
        isRunning = false
    end)
end

-- Keybind setup
local UserInputService = game:GetService("UserInputService")

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.End then
        autoLeave()
    end
end)


local ReplicatedStorage = game:GetService("ReplicatedStorage")
