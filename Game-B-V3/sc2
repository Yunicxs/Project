-- Fade In Animation ===============================================

local TweenService = game:GetService("TweenService")

local FadeTween = TweenInfo.new(
	1,
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)

local function PrepareObject(Object)
	if Object == GhostStatus or Object == PlayerStatus then
		return
	end

	if Object:IsA("Frame") then
		Object.BackgroundTransparency = 1

	elseif Object:IsA("TextLabel") or Object:IsA("TextButton") then
		Object.TextTransparency = 1
		Object.TextStrokeTransparency = 1

	elseif Object:IsA("ImageLabel") or Object:IsA("ImageButton") then
		Object.ImageTransparency = 1

	elseif Object:IsA("UIStroke") then
		Object.Transparency = 1
	end
end

local function FadeObject(Object)
	if Object == GhostStatus or Object == PlayerStatus then
		return
	end

	if Object:IsA("Frame") then
		TweenService:Create(Object, FadeTween, {
			BackgroundTransparency = 0
		}):Play()

	elseif Object:IsA("TextLabel") or Object:IsA("TextButton") then
		TweenService:Create(Object, FadeTween, {
			TextTransparency = 0,
			TextStrokeTransparency = 1
		}):Play()

	elseif Object:IsA("ImageLabel") or Object:IsA("ImageButton") then
		TweenService:Create(Object, FadeTween, {
			ImageTransparency = 0
		}):Play()

	elseif Object:IsA("UIStroke") then
		TweenService:Create(Object, FadeTween, {
			Transparency = 0
		}):Play()
	end
end

for _,Object in ipairs(StatusUI:GetDescendants()) do
	PrepareObject(Object)
end

task.wait()

for _,Object in ipairs(StatusUI:GetDescendants()) do
	task.spawn(function()
		FadeObject(Object)
	end)
end

