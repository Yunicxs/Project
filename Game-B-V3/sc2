-- GhostRoomCheck Script
-- Detects coldest zone (lowest _____LocalBaseTemp value)
-- Displays zone name directly via BillboardGui (white bold text, small, with UIStroke)
-- Excludes "Outside" zones

local ZonesFolder = workspace:WaitForChild("Map"):WaitForChild("Zones")

local ghostRoomBillboard = nil

-- Helper: safely get child
local function safeGet(parent, name)
	if not parent then return nil end
	return parent:FindFirstChild(name)
end

-- Find the coldest zone using _____LocalBaseTemp, excluding Outside
local function findColdestZone()
	local coldestZone = nil
	local lowestTemp = math.huge

	for _, zone in ipairs(ZonesFolder:GetChildren()) do
		-- Skip Outside zones (safe zone)
		if zone.Name == "Outside" then
			continue
		end

		if zone:IsA("BasePart") and safeGet(zone, "IsZone") then
			if not zone.IsZone.Value then continue end

			-- Check for Exclude flag
			local exclude = safeGet(zone, "Exclude")
			if exclude and exclude.Value == true then
				continue
			end

			-- Get _____LocalBaseTemp value
			local tempObj = safeGet(zone, "_____Temperature")
			if tempObj then
				local baseTemp = safeGet(tempObj, "_____LocalBaseTemp")
				if baseTemp and baseTemp.Value < lowestTemp then
					lowestTemp = baseTemp.Value
					coldestZone = zone
				end
			end
		end
	end

	return coldestZone
end

-- Create BillboardGui for displaying Ghost Room
local function createBillboardGUI(zonePart, zoneName)
	if not zonePart then return end

	-- Clean up existing billboard
	if ghostRoomBillboard and ghostRoomBillboard.Parent then
		ghostRoomBillboard:Destroy()
	end

	ghostRoomBillboard = Instance.new("BillboardGui")
	ghostRoomBillboard.Name = "GhostRoomDisplay"
	ghostRoomBillboard.Parent = zonePart
	ghostRoomBillboard.Adornee = zonePart
	ghostRoomBillboard.Size = UDim2.new(0, 100, 0, 30)
	ghostRoomBillboard.StudsOffset = Vector3.new(0, 3, 0)
	ghostRoomBillboard.AlwaysOnTop = true
	ghostRoomBillboard.LightInfluence = 0

	local textLabel = Instance.new("TextLabel")
	textLabel.Name = "ZoneText"
	textLabel.Parent = ghostRoomBillboard
	textLabel.Size = UDim2.new(0.7, 0, 0.7, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.Text = zoneName
	textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	textLabel.TextScaled = true
	textLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
	textLabel.TextStrokeTransparency = 0
	textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

	local uiStroke = Instance.new("UIStroke")
	uiStroke.Parent = textLabel
	uiStroke.Thickness = 1
	uiStroke.Color = Color3.fromRGB(0, 0, 0)

end

-- Update Ghost Room detection and display
local function updateGhostRoom()
	if not ZonesFolder then return end

	local coldestZone = findColdestZone()
	if coldestZone then
		createBillboardGUI(coldestZone, coldestZone.Name)
	else
		if ghostRoomBillboard and ghostRoomBillboard.Parent then
			ghostRoomBillboard:Destroy()
		end
	end
end

-- Main update loop
task.spawn(function()
	while true do
		if not ZonesFolder or not ZonesFolder.Parent then break end
		updateGhostRoom()
		task.wait(1)
	end
end)

